rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnEmail(email) {
      return isSignedIn() && request.auth.token.email == email;
    }

    function userDocIsReadable(userId) {
      return isSignedIn() && (
        userId == request.auth.uid ||
        resource.data.email == request.auth.token.email
      );
    }

    function userDocIsWritable(userId) {
      return isSignedIn() && (
        userId == request.auth.uid ||
        resource.data.email == request.auth.token.email
      ) && !('password' in request.resource.data);
    }

    function userDocCanBeCreated(userId) {
      return isSignedIn()
        && userId == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && !('password' in request.resource.data);
    }

    function favoriteBelongsToUser() {
      return isSignedIn() && (
        resource.data.userId == request.auth.token.email ||
        resource.data.userId == request.auth.uid
      );
    }

    function favoriteCreateBelongsToUser() {
      return isSignedIn() && (
        request.resource.data.userId == request.auth.token.email ||
        request.resource.data.userId == request.auth.uid
      );
    }

    match /User/{userId} {
      allow read: if userDocIsReadable(userId);
      allow create: if userDocCanBeCreated(userId);
      allow update: if userDocIsWritable(userId);
      allow delete: if userDocIsReadable(userId);
    }

    match /ProfileData/{profileId} {
      allow read, create, update, delete: if isOwnEmail(profileId);
    }

    match /UserReview/{reviewId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSignedIn()
        && resource.data.get('authorUid', '') == request.auth.uid;
    }

    match /UserRating/{ratingId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /Favorites/{favoriteId} {
      allow read: if favoriteBelongsToUser();
      allow create: if favoriteCreateBelongsToUser();
      allow update, delete: if favoriteBelongsToUser();
    }

    match /Accommodation/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
